{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "R7-ROOT-2: mutation testing config. Initial scope: lib/dharma.ts + lib/dayOfYear.ts + lib/timeOffset.ts — the three pure libs most exercised across the date-math bug class. Expand to lib/history.ts, lib/appliesOn.ts etc. once the baseline holds.",
  "packageManager": "npm",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "reporters": ["progress", "clear-text", "html"],
  "mutate": ["lib/dharma.ts", "lib/dayOfYear.ts", "lib/timeOffset.ts"],
  "ignorePatterns": ["**/*.test.ts", "**/*.test.tsx", "**/*.tz.test.ts"],
  "thresholds": {
    "high": 90,
    "low": 75,
    "break": 60
  },
  "coverageAnalysis": "off",
  "timeoutMS": 30000,
  "concurrency": 4,
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "logLevel": "info",
  "fileLogLevel": "trace",
  "incremental": true,
  "incrementalFile": ".stryker-tmp/incremental.json"
}
